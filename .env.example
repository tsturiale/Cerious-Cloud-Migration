# Cerious Systems environment template
# Copy to .env for local runs, or provide the same names as cloud secrets.

# Runtime mode
CERIOUS_DRY_RUN=1
CERIOUS_PRICE_PROVIDER=databento

# Gateway / frontend hosting
CERIOUS_BACKEND_HOST=127.0.0.1
CERIOUS_BACKEND_PORT=8000
CERIOUS_FRONTEND_HOST=127.0.0.1
CERIOUS_FRONTEND_PORT=5173
CERIOUS_GATEWAY_HTTP=http://127.0.0.1:8000
CERIOUS_GATEWAY_WS=ws://127.0.0.1:8000
CERIOUS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_CERIOUS_WS_BASE=

# Databento CME feed
DATABENTO_API_KEY=
CERIOUS_CME_DATASET=GLBX.MDP3
CERIOUS_CME_SCHEMA=mbp-1
CERIOUS_CME_SYMBOLS=ES.v.0,NQ.v.0,YM.v.0,RTY.v.0,CL.v.0,GC.v.0,ZM.v.0,ZS.v.0

# T4 SIM feed/order API
T4_AUTH_MODE=api_key
T4_API_KEY=
T4_WS_URL=wss://wss-sim.t4login.com/v1
T4_API_URL=https://api-sim.t4login.com
T4_FIRM=
T4_USERNAME=
T4_PASSWORD=
T4_APP_NAME=Cerious Systems
T4_APP_LICENSE=
T4_EXCHANGE_ID=CME_Eq
T4_CONTRACTS=ES,NQ,YM,RTY,CL,GC,ZM,ZS
T4_MARKETS=
T4_MARKET_IDS=

# Portal/auth
CERIOUS_PORTAL_USERNAME=
CERIOUS_PORTAL_PASSWORD=
CERIOUS_AUTH_SECRET=

# Alerts
CERIOUS_ALERT_SMS_WEBHOOK_URL=
CERIOUS_ALERT_SMS_WEBHOOK_BEARER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Optional legacy algo/backend clients
CERIOUS_BACKEND_BASE_URL=
CERIOUS_CRYPTO_DATA_DIR=

# FIX Engine — C++ daemon (native/fix-engine-cpp)
FIX_MODE=sim
FIX_SENDER_COMP_ID=CERIOUS
FIX_TARGET_COMP_ID=TT_SIM
FIX_TARGET_HOST=
FIX_TARGET_PORT=0
FIX_HEARTBEAT_INTERVAL=30
FIX_VERSION=FIX.4.4
FIX_ACCOUNT=
FIX_PASSWORD=
FIX_HTTP_HOST=127.0.0.1
FIX_HTTP_PORT=8010

# E2E test endpoints
CERIOUS_E2E_BASE_URL=http://127.0.0.1:5173
CERIOUS_E2E_API_URL=http://127.0.0.1:8000
